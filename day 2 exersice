# 🌟 EXERCISE 2: DOGS
# ==========================================
class Dog:
    def __init__(self, name, height):
        self.name = name
        self.height = height

    def bark(self):
        print(f"{self.name} goes woof!")

    def jump(self):
        x = self.height * 2
        print(f"{self.name} jumps {x} cm high!")

print(f"--- Exercise 2 ---")
davids_dog = Dog("Rex", 50)
sarahs_dog = Dog("Teacup", 20)

print(f"David's dog: {davids_dog.name}, Height: {davids_dog.height}")
davids_dog.bark()
davids_dog.jump()

print(f"Sarah's dog: {sarahs_dog.name}, Height: {sarahs_dog.height}")
sarahs_dog.bark()
sarahs_dog.jump()

# Comparing sizes
if davids_dog.height > sarahs_dog.height:
    print(f"The bigger dog is {davids_dog.name}.\n")
else:
    print(f"The bigger dog is {sarahs_dog.name}.\n")


