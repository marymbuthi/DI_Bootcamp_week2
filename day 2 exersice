# 🌟 EXERCISE 1: CATS
# ==========================================
class Cat:
    def __init__(self, cat_name, cat_age):
        self.name = cat_name
        self.age = cat_age

def find_oldest_cat(cat1, cat2, cat3):
    # Logic to compare ages and return the object
    if cat1.age > cat2.age and cat1.age > cat3.age:
        return cat1
    elif cat2.age > cat1.age and cat2.age > cat3.age:
        return cat2
    else:
        return cat3

# Step 1: Instantiate 3 cats
c1 = Cat("Whiskers", 3)
c2 = Cat("Luna", 7)
c3 = Cat("Mittens", 5)

# Step 3: Print result
oldest = find_oldest_cat(c1, c2, c3)
print(f"--- Exercise 1 ---")
print(f"The oldest cat is {oldest.name}, and is {oldest.age} years old.\n")


