class Cat:
    def __init__(self, name, age, color):
        self.name = name
        self.age = age
        self.color = color
    
    def meow(self):
        return f"{self.name} says meow!"
    
    def __str__(self):
        return f"Cat(name={self.name}, age={self.age}, color={self.color})"


# Create three cat objects
cat1 = Cat("Whiskers", 3, "Orange")
cat2 = Cat("Mittens", 2, "Black")
cat3 = Cat("Luna", 4, "Gray")

# Test the cat objects
print(cat1)
print(cat2)
print(cat3)

print(cat1.meow())
print(cat2.meow())
print(cat3.meow())

# Function to find the eldest cat
def find_eldest(cats):
    """Find and return the eldest cat from a list of Cat objects."""
    if not cats:
        return None
    return max(cats, key=lambda cat: cat.age)

# Test the function
eldest = find_eldest([cat1, cat2, cat3])
print(f"\nThe eldest cat is: {eldest.name} ({eldest.age} years old)")


class Dog:
