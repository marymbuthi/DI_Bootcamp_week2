class AnagramChecker:
    def __init__(self, file_path="words.txt"):
        """Loads the word list from a file into a set for fast lookup."""
        try:
            with open(file_path, 'r') as file:
                # Store in a set for O(1) lookup speed
                self.word_list = {line.strip().lower() for line in file}
        except FileNotFoundError:
            print(f"Error: The file {file_path} was not found.")
            self.word_list = set()

    def is_valid_word(self, word):
        """Checks if the word exists in the dictionary."""
        return word.lower() in self.word_list

    def is_anagram(self, word1, word2):
        """Checks if two words contain the exact same letters."""
        w1, w2 = word1.lower(), word2.lower()
        # A word is not an anagram of itself
        if w1 == w2:
            return False
        return sorted(w1) == sorted(w2)

    def get_anagrams(self, word):
        """Returns a list of all anagrams found in the word list."""
        word = word.lower()
        return [w for w in self.word_list if self.is_anagram(word, w)]m
