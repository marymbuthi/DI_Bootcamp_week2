# EXERCISE 2: DOGS
# ==========================================
class Dog:
    def __init__(self, name, height):
        self.name = name
        self.height = height

    def bark(self):
        print(f"{self.name} goes woof!")

    def jump(self):
        x = self.height * 2
        print(f"{self.name} jumps {x} cm high!")

print("--- Exercise 2: Dogs ---")
davids_dog = Dog("Rex", 50)
sarahs_dog = Dog("Teacup", 20)

# Calling methods for David's dog
print(f"David's dog: {davids_dog.name}, Height: {davids_dog.height}cm")
davids_dog.bark()
davids_dog.jump()

# Calling methods for Sarah's dog
print(f"Sarah's dog: {sarahs_dog.name}, Height: {sarahs_dog.height}cm")
sarahs_dog.bark()
sarahs_dog.jump()

# Comparing sizes
if davids_dog.height > sarahs_dog.height:
    print(f"The bigger dog is {davids_dog.name}.\n")
else:
    print(f"The bigger dog is {sarahs_dog.name}.\n")


