import random

class Game:
    def __init__(self):
        self.valid_items = ['rock', 'paper', 'scissors']

    def get_user_item(self):
        """Asks and validates the user's move."""
        while True:
            user_input = input("Select an item (rock/paper/scissors): ").lower().strip()
            if user_input in self.valid_items:
                return user_input
            print("Invalid selection. Please try again.")

    def get_computer_item(self):
        """Randomly selects the computer's move."""
        return random.choice(self.valid_items)

    def get_game_result(self, user_item, computer_item):
        """Determines the winner based on RPS rules."""
        if user_item == computer_item:
            return "draw"
        
        # Win conditions for the user
        win_conditions = {
            "rock": "scissors",
            "paper": "rock",
            "scissors": "paper"
        }
        
        if win_conditions[user_item] == computer_item:
            return "win"
        else:
            return "loss"

    def play(self):
        """Executes one full round and returns the result."""
        user_choice = self.get_user_item()
        computer_choice = self.get_computer_item()
        result = self.get_game_result(user_choice, computer_choice)
        
        print(f"You chose: {user_choice}. Computer chose: {computer_choice}.")
        print(f"Result: {result.upper()}!")
        
        return result
