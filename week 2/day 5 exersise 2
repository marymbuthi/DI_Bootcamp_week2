def get_user_menu_choice():
    """Displays the main menu and validates the selection."""
    print("\n--- Main Menu ---")
    print("(g) Play a new game")
    print("(x) Show scores and quit")
    
    while True:
        choice = input("Select an option: ").lower().strip()
        if choice in ['g', 'x']:
            return choice
        print("Invalid choice. Enter 'g' to play or 'x' to exit.")

def print_results(results):
    """Formats and prints the final score summary."""
    print("\n--- Game Summary ---")
    print(f"Wins:   {results['win']}")
    print(f"Losses: {results['loss']}")
    print(f"Draws:  {results['draw']}")
    print("\nThank you for playing!")

def main():
    # Initialize results dictionary
    results = {"win": 0, "loss": 0, "draw": 0}
    
    while True:
        user_choice = get_user_menu_choice()
        
        if user_choice == 'g':
            # Create a new Game instance for each round
            current_round = Game()
            outcome = current_round.play()
            
            # Update the results dictionary
            results[outcome] += 1
            
        elif user_choice == 'x':
            print_results(results)
            break

if __name__ == "__main__":
    main()